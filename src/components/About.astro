---
// src/components/About.astro

const stack = [
  { name:'Astro',       logo:'⚡', color:'#FF5D01' },
  { name:'Next.js',     logo:'▲',  color:'#ffffff' },
  { name:'TypeScript',  logo:'TS', color:'#3178C6' },
  { name:'Tailwind',    logo:'◈',  color:'#38BDF8' },
  { name:'Cloudflare',  logo:'☁',  color:'#F48120' },
  { name:'Figma',       logo:'◉',  color:'#A259FF' },
  { name:'Supabase',    logo:'⬡',  color:'#3ECF8E' },
  { name:'Vercel',      logo:'△',  color:'#ffffff' },
];
---

<section id="tentang" class="py-32 px-6 relative overflow-hidden">
  <div class="absolute inset-0 mesh-bg opacity-50"></div>
  <div class="absolute top-0 left-0 right-0 line-gradient opacity-40"></div>

  <div class="max-w-6xl mx-auto relative z-10">

    <!-- Two-col layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-24">

      <!-- Left: text -->
      <div class="reveal">
        <p class="section-label mb-4">// 04 — TENTANG KAMI</p>
        <h2 class="font-display font-bold text-white mb-6"
            style="font-size:clamp(2rem,4.5vw,3.2rem); line-height:1.1;">
          Studio di balik<br/>
          <span class="text-gradient-cyan">obotzone.id</span>
        </h2>
        <div class="space-y-4 text-white/50 font-light leading-relaxed text-[0.95rem]">
          <p>
            Kami adalah tim kecil yang bersemangat tentang teknologi web modern.
            Berdiri sejak 2019, Obotzone telah membantu puluhan bisnis dan startup
            Indonesia tampil profesional di dunia digital.
          </p>
          <p>
            Filosofi kami sederhana: website yang bagus bukan cuma soal tampilan —
            ia harus cepat, mudah dikelola, dan menghasilkan hasil nyata bagi bisnis kamu.
          </p>
        </div>

        <div class="flex flex-wrap gap-4 mt-8">
          <a href="#kontak" class="btn-primary">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
            </svg>
            Ngobrol Bareng Kami
          </a>
        </div>
      </div>

      <!-- Right: values grid -->
      <div class="reveal reveal-delay-2 grid grid-cols-2 gap-4">
        {[
          { title:'Performance First', desc:'Setiap proyek ditargetkan Lighthouse 95+', icon:'⚡', color:'#00d4ff' },
          { title:'Mobile Native',     desc:'Dirancang untuk semua ukuran layar',         icon:'📱', color:'#00ff88' },
          { title:'Edge Deployed',     desc:'Cloudflare CDN di 300+ kota dunia',          icon:'🌐', color:'#00d4ff' },
          { title:'Open Source',       desc:'Kode bersih, terdokumentasi, maintainable',  icon:'⬡',  color:'#00ff88' },
        ].map(v => (
          <div class="glass glass-hover p-5" style="border-radius:14px;">
            <div class="text-2xl mb-3">{v.icon}</div>
            <h4 class="font-display font-semibold text-white text-[0.9rem] mb-1.5">{v.title}</h4>
            <p class="text-white/35 text-xs leading-relaxed font-light">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Tech stack -->
    <div class="reveal">
      <p class="section-label mb-8 text-center">// TECH STACK YANG KAMI GUNAKAN</p>
      <div class="grid grid-cols-4 md:grid-cols-8 gap-3">
        {stack.map(s => (
          <div class="glass glass-hover flex flex-col items-center justify-center gap-2 py-5 px-3 group"
               style="border-radius:12px;">
            <span class="font-mono text-xl font-bold transition-all duration-300"
                  style={`color:${s.color};`}>
              {s.logo}
            </span>
            <span class="font-mono text-[0.6rem] text-white/30 group-hover:text-white/60 transition-colors tracking-wider">
              {s.name}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
