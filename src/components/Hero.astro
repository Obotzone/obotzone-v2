---
// src/components/Hero.astro
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col justify-center
         mesh-bg dot-grid overflow-hidden pt-28 pb-20 px-6"
>

  <!-- ── Ambient orbs ──────────────────────────────── -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <!-- Cyan orb top-left -->
    <div
      class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full opacity-[0.12]"
      style="background: radial-gradient(circle, #00d4ff 0%, transparent 65%); animation: float 8s ease-in-out infinite;"
    ></div>
    <!-- Emerald orb bottom-right -->
    <div
      class="absolute -bottom-60 -right-20 w-[500px] h-[500px] rounded-full opacity-[0.09]"
      style="background: radial-gradient(circle, #00ff88 0%, transparent 65%); animation: float 10s ease-in-out infinite reverse;"
    ></div>
    <!-- Center subtle glow -->
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
             w-[800px] h-[400px] opacity-[0.04] rounded-full"
      style="background: radial-gradient(ellipse, #0088ff 0%, transparent 70%);"
    ></div>
  </div>

  <!-- ── Floating badge ───────────────────────────── -->
  <div class="relative z-10 max-w-5xl mx-auto w-full">
    <div class="reveal flex items-center gap-3 mb-8">
      <span class="tag">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald animate-pulse inline-block"></span>
        // SYSTEM ONLINE
      </span>
      <span class="tag" style="background:rgba(0,255,136,0.06); border-color:rgba(0,255,136,0.2); color:#00ff88;">
        v2.0 — 2025
      </span>
    </div>

    <!-- ── Headline ──────────────────────────────────── -->
    <h1 class="reveal reveal-delay-1 font-display font-extrabold leading-[1.0] tracking-tight mb-6"
        style="font-size: clamp(3.2rem, 8vw, 7rem);">
      <span class="block text-white">Kami Membangun</span>
      <span class="block text-gradient-cyan">Produk Digital</span>
      <span class="block text-white/70 font-light"
            style="font-size: clamp(2rem, 5vw, 4.5rem);">
        Yang Benar‑Benar Bekerja.
      </span>
    </h1>

    <!-- ── Sub ──────────────────────────────────────── -->
    <p class="reveal reveal-delay-2 max-w-xl text-white/55 leading-relaxed mb-10"
       style="font-size: clamp(1rem, 2vw, 1.15rem); font-weight: 300;">
      Obotzone adalah studio teknologi yang merancang dan mengembangkan
      website, web app, dan sistem digital dengan performa tinggi —
      dari konsep hingga produksi.
    </p>

    <!-- ── CTAs ─────────────────────────────────────── -->
    <div class="reveal reveal-delay-3 flex flex-wrap items-center gap-4 mb-20">
      <a href="#portfolio" class="btn-primary text-base px-7 py-3.5">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/>
          <rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        Lihat Portfolio
      </a>
      <a href="#kontak" class="btn-secondary text-base px-7 py-3.5">
        Diskusi Proyek
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- ── Stats bar ─────────────────────────────────── -->
    <div class="reveal reveal-delay-4"
         data-stagger
         style="display:grid; grid-template-columns: repeat(auto-fit, minmax(130px,1fr)); gap:1px;
                background: rgba(255,255,255,0.05); border-radius:14px; overflow:hidden;">
      {[
        { value: '50+',    label: 'Proyek Selesai' },
        { value: '30+',    label: 'Klien Aktif' },
        { value: '5 thn',  label: 'Pengalaman' },
        { value: '99.9%',  label: 'Uptime SLA' },
      ].map(s => (
        <div class="glass-hover flex flex-col items-center justify-center py-6 px-4 text-center"
             style="border-radius:0; background:rgba(255,255,255,0.03);">
          <span class="font-display font-bold text-2xl text-gradient-cyan mb-1">{s.value}</span>
          <span class="font-mono text-[0.65rem] text-white/40 tracking-widest uppercase">{s.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ── Floating tech card (decorative) ──────────── -->
  <div class="pointer-events-none absolute right-8 top-1/2 -translate-y-1/2
              hidden xl:block animate-float opacity-70"
       style="animation-duration: 7s;">
    <div class="glass p-5 w-64" style="border-radius:16px;">
      <!-- Scan bar -->
      <div class="relative overflow-hidden h-0.5 bg-white/5 rounded mb-4">
        <div class="absolute top-0 left-0 h-full w-1/3 bg-gradient-to-r from-transparent via-cyan to-transparent"
             style="animation: scan 2.5s linear infinite;"></div>
      </div>
      <p class="font-mono text-[0.65rem] text-cyan/60 mb-3 tracking-widest">// PERFORMANCE_METRICS</p>
      {[
        { label: 'Lighthouse Score', value: '99', color: '#00ff88' },
        { label: 'Page Load',        value: '0.8s', color: '#00d4ff' },
        { label: 'Core Web Vitals',  value: 'PASS', color: '#00ff88' },
        { label: 'Build Time',       value: '1.2s', color: '#00d4ff' },
      ].map(m => (
        <div class="flex items-center justify-between py-1.5 border-b border-white/05">
          <span class="font-mono text-[0.65rem] text-white/40">{m.label}</span>
          <span class="font-mono text-xs font-semibold" style={`color:${m.color}`}>{m.value}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ── Bottom separator ─────────────────────────── -->
  <div class="absolute bottom-0 left-0 right-0 line-gradient opacity-60"></div>
</section>

<style>
  @keyframes scan {
    from { transform: translateX(-150%); }
    to   { transform: translateX(450%); }
  }
</style>
